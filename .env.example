ADMIN_USERNAME=change_me_admin
ADMIN_PASSWORD=change_me_password
RESET_CODE=change_me_reset_code
ACCOUNT_CREATE_CODE=change_me_extra_account_code
# Keep webhook URLs and OAuth secrets only in the live server's .env.
RESET_WEBHOOK_URL=
SUBMISSION_WEBHOOK_URL=
DECISION_WEBHOOK_URL=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
PORT=8134
HOST=0.0.0.0
DATA_DIR=
# Set one deploy target:
# 1) local-copy: put a filesystem path in DEPLOY_LOCAL_DIR
# 2) rsync over SSH: set DEPLOY_HOST and DEPLOY_PATH, plus DEPLOY_USER if needed
DEPLOY_METHOD=
DEPLOY_LOCAL_DIR=
DEPLOY_USER=
DEPLOY_HOST=
DEPLOY_PATH=
DEPLOY_SSH_PORT=22
WATCH_INTERVAL_SECONDS=5
